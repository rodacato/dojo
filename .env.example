# Database
DATABASE_URL=postgresql://dojo:dojo@db:5432/dojo_dev

# Database (production Docker — docker-compose.yml)
POSTGRES_USER=dojo
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=dojo

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# LLM
LLM_ADAPTER_FORMAT=anthropic       # anthropic | openai | mock
LLM_STREAM=true                    # true for token-by-token streaming, false for single HTTP request
LLM_BASE_URL=https://api.anthropic.com
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# Code Execution (Piston — sandboxed code runner for kata tests)
CODE_EXECUTION_ENABLED=false           # true to run code via Piston, false for mock
PISTON_URL=http://piston:2000          # Dev: http://piston:2000 | Prod (Kamal): http://dojo-api-piston:2000
PISTON_MAX_CONCURRENT=3                # Max concurrent executions
PISTON_RUN_TIMEOUT=3000                # Run timeout in ms (TS runtime is capped at 3000 by Piston package metadata)
PISTON_COMPILE_TIMEOUT=30000           # Compile timeout in ms (Rust needs more)

# Drawhaus
DRAWHAUS_URL=https://drawhaus.notdefined.dev

# Session / Auth
SESSION_SECRET=change-me-to-a-random-string
CREATOR_GITHUB_ID=               # GitHub numeric ID of the creator (Phase 0 admin access)

# Email (Resend — optional, for sending invitation emails)
RESEND_API_KEY=                   # Get from https://resend.com/api-keys
RESEND_FROM_EMAIL=dojo <noreply@notdefined.dev>  # Must be verified domain in Resend

# App
API_PORT=3001
WEB_PORT=5173
WEB_URL=http://localhost:5173    # Used by API for share cards, email links
VITE_API_URL=http://localhost:3001
NODE_ENV=development

# Cron (optional — protects the POST /cron/reminders endpoint)
CRON_SECRET=                     # Set a random string in production

# Observability — Sentry (optional; empty DSN disables Sentry sinks)
# Both SENTRY_DSN (API, @sentry/node) and VITE_SENTRY_DSN (web, @sentry/react)
# are independent. Leave both empty to run on Console + Postgres sinks only.
SENTRY_DSN=                                    # API DSN — from sentry.io project settings
SENTRY_ENVIRONMENT=production                  # Tag applied to every event
SENTRY_TRACES_SAMPLE_RATE=0                    # 0..1 — keep at 0 until we opt into tracing
SENTRY_RELEASE=                                # Usually the deploy's git SHA; Kamal fills this
VITE_SENTRY_DSN=                               # Web DSN — from sentry.io project settings
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=                           # Release name for web; match SENTRY_RELEASE

# Source map upload (build-time only, Web). Required together to upload; leave
# empty to skip upload (local builds, CI without Sentry access).
SENTRY_AUTH_TOKEN=                             # Sentry auth token with project:releases scope
SENTRY_ORG=                                    # Sentry org slug
SENTRY_PROJECT=                                # Sentry web project slug
