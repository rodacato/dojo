# ============================================================================
# dojo_ — copy this file to `.env` and fill in the values marked SECRET.
# Everything else is a sane default for local development (`pnpm dev`).
# ============================================================================

# ---- Database --------------------------------------------------------------
DATABASE_URL=postgresql://dojo:dojo@db:5432/dojo_dev
POSTGRES_USER=dojo
POSTGRES_DB=dojo
POSTGRES_PASSWORD=dojo                            # SECRET (prod) — strong password required in production

# ---- App -------------------------------------------------------------------
NODE_ENV=development
API_PORT=3001
WEB_PORT=5173
WEB_URL=http://localhost:5173                     # Used by API for share cards, email links
VITE_API_URL=http://localhost:3001

# ---- Auth & Sessions -------------------------------------------------------
SESSION_SECRET=dev-secret-change-me-in-production-must-be-at-least-32-characters    # SECRET (prod) — random ≥32 chars
CREATOR_GITHUB_ID=                                # SECRET — your GitHub numeric id (gates /admin)
GITHUB_CLIENT_ID=                                 # SECRET — github.com/settings/applications/new
GITHUB_CLIENT_SECRET=                             # SECRET — paired with GITHUB_CLIENT_ID
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ---- LLM (sensei) ----------------------------------------------------------
# `mock` requires no API key — good default for local dev.
# Switch to `anthropic` or `openai` and set LLM_API_KEY for real responses.
LLM_ADAPTER_FORMAT=mock                           # anthropic | openai | mock
LLM_STREAM=true                                   # true = token-by-token stream over WS
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=                                      # SECRET — required when LLM_ADAPTER_FORMAT != mock

# ---- Code execution (Piston sandbox) --------------------------------------
CODE_EXECUTION_ENABLED=false                      # false → mock (fast dev); true → real Piston runtime
PISTON_URL=http://piston:2000                     # Kamal prod: http://dojo-api-piston:2000
PISTON_MAX_CONCURRENT=3
PISTON_RUN_TIMEOUT=3000                           # ms — TS runtime is capped at 3000 by Piston
PISTON_COMPILE_TIMEOUT=30000                      # ms — Rust needs the headroom

# ---- External services -----------------------------------------------------
DRAWHAUS_URL=https://drawhaus.notdefined.dev
RESEND_FROM_EMAIL=dojo <noreply@notdefined.dev>   # Must be a verified domain in Resend
RESEND_API_KEY=                                   # SECRET — resend.com/api-keys (emails disabled when empty)

# ---- Cron (prod protection) -----------------------------------------------
CRON_SECRET=                                      # SECRET — random string; protects POST /cron/reminders

# ============================================================================
# Observability — Sentry (optional)
# Leave DSNs empty to run on Console + Postgres sinks only. Filling them in
# activates the Sentry sink on top (both run in parallel via the Composite).
# ============================================================================

# ---- Runtime (API + web) --------------------------------------------------
SENTRY_DSN=                                       # SECRET — API project DSN
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0                       # 0..1 — keep 0 until opting into tracing
SENTRY_RELEASE=                                   # Deploy sets this to the git SHA
VITE_SENTRY_DSN=                                  # SECRET — web project DSN
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_RELEASE=                              # Match SENTRY_RELEASE

# ---- Build-time: source map upload (web only) -----------------------------
# All three required together; missing any one silently skips the upload.
SENTRY_AUTH_TOKEN=                                # SECRET — org token with org:ci scope
SENTRY_ORG=                                       # Your Sentry org slug
SENTRY_PROJECT=dojo-web                           # Sentry project slug for the web build
