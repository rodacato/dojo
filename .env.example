# ============================================================================
# dojo_ ‚Äî copy this file to `.env` and fill in the values marked SECRET.
# Everything else is a sane default for local development (`pnpm dev`).
# ============================================================================

# ---- Database --------------------------------------------------------------
DATABASE_URL=postgresql://dojo:dojo@db:5432/dojo_dev
POSTGRES_USER=dojo
POSTGRES_DB=dojo
POSTGRES_PASSWORD=dojo                            # SECRET (prod) ‚Äî strong password required in production

# ---- App -------------------------------------------------------------------
NODE_ENV=development
API_PORT=3001
WEB_PORT=5173
WEB_URL=http://localhost:5173                     # Used by API for share cards, email links
VITE_API_URL=http://localhost:3001

# ---- Auth & Sessions -------------------------------------------------------
SESSION_SECRET=dev-secret-change-me-in-production-must-be-at-least-32-characters    # SECRET (prod) ‚Äî random ‚â•32 chars
CREATOR_GITHUB_ID=                                # SECRET ‚Äî your GitHub numeric id (gates /admin)
GITHUB_CLIENT_ID=                                 # SECRET ‚Äî github.com/settings/applications/new
GITHUB_CLIENT_SECRET=                             # SECRET ‚Äî paired with GITHUB_CLIENT_ID
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ---- LLM (sensei) ----------------------------------------------------------
# `mock` requires no API key ‚Äî good default for local dev.
# Switch to `anthropic` or `openai` and set LLM_API_KEY for real responses.
FF_COURSE_NUDGE_ENABLED=false                     # PRD 026 ‚Äî "Ask the sensei" nudges; flip on after prompt signoff
LLM_ADAPTER_FORMAT=mock                           # anthropic | openai | mock
LLM_STREAM=true                                   # true = token-by-token stream over WS
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=                                      # SECRET ‚Äî required when LLM_ADAPTER_FORMAT != mock

# ---- Code execution (Piston sandbox) --------------------------------------
FF_CODE_EXECUTION_ENABLED=false                   # false ‚Üí mock (fast dev); true ‚Üí real Piston runtime
PISTON_URL=http://piston:2000                     # Kamal prod: http://dojo-api-piston:2000
PISTON_MAX_CONCURRENT=3
PISTON_RUN_TIMEOUT=3000                           # ms ‚Äî TS runtime is capped at 3000 by Piston
PISTON_COMPILE_TIMEOUT=30000                      # ms ‚Äî Rust needs the headroom

# ---- External services -----------------------------------------------------
DRAWHAUS_URL=https://drawhaus.notdefined.dev
RESEND_FROM_EMAIL=dojo <noreply@notdefined.dev>   # Must be a verified domain in Resend
RESEND_API_KEY=                                   # SECRET ‚Äî resend.com/api-keys (emails disabled when empty)

# ---- Cron (prod protection) -----------------------------------------------
CRON_SECRET=                                      # SECRET ‚Äî random string; protects POST /cron/reminders

# ============================================================================
# Observability ‚Äî Sentry (optional)
# Leave DSNs empty to run on Console + Postgres sinks only. Filling them in
# activates the Sentry sink on top (both run in parallel via the Composite).
#
# Environment gating: the Sentry adapter is SKIPPED when the environment is
# `development` or `test`, even if a DSN is set ‚Äî so a prod `.env` copied to
# a laptop doesn't spray dev errors into prod Sentry. Set SENTRY_ENVIRONMENT
# to `staging` or `production` to enable reporting.
#   API:  defaults to NODE_ENV when empty.
#   Web:  defaults to Vite's build mode when empty (`development` for
#         `pnpm dev`, `production` for `pnpm build`).
# ============================================================================

# ---- Runtime (API + web) --------------------------------------------------
SENTRY_DSN=                                       # SECRET ‚Äî API project DSN
SENTRY_ENVIRONMENT=                               # empty ‚Üí NODE_ENV ¬∑ set to staging|production to enable Sentry
SENTRY_TRACES_SAMPLE_RATE=0                       # 0..1 ‚Äî keep 0 until opting into tracing
SENTRY_RELEASE=                                   # Deploy sets this to the git SHA
VITE_SENTRY_DSN=                                  # SECRET ‚Äî web project DSN
VITE_SENTRY_ENVIRONMENT=                          # empty ‚Üí Vite MODE ¬∑ set to staging|production to enable Sentry
VITE_SENTRY_RELEASE=                              # Match SENTRY_RELEASE

# ---- Build-time: source map upload (web only) -----------------------------
# Runtime events are already routed by the DSNs above (each DSN encodes its
# own project). These vars only drive `@sentry/vite-plugin` during the web
# build to upload source maps + tag the release. The API is NOT wired for
# source map upload yet ‚Äî its stack frames point to the compiled bundle.
# All three required together; missing any one silently skips the upload.
SENTRY_AUTH_TOKEN=                                # SECRET ‚Äî org token with org:ci scope
SENTRY_ORG=                                       # Your Sentry org slug
SENTRY_PROJECT=dojo-web                           # Sentry project slug for the web build

# ---- Playground (public anonymous code execution) -------------------------
# Behind FF_PLAYGROUND_CONSOLE_ENABLED. Do NOT flip to true in prod until
# all four abuse-stack layers (Turnstile + per-IP RL + per-session RL +
# global daily quota) are in place. See docs/specs/027-sprint-022-playground.md ¬ß4.
FF_PLAYGROUND_CONSOLE_ENABLED=false               # master gate for /playground/run
PLAYGROUND_RATE_LIMIT_ANON_PER_MIN=10             # anon per-IP + per-session ceiling (minute)
PLAYGROUND_RATE_LIMIT_ANON_PER_DAY=100            # anon per-IP + per-session ceiling (day)
PLAYGROUND_RATE_LIMIT_AUTHED_PER_MIN=60           # authed per-user ceiling (minute)
PLAYGROUND_RATE_LIMIT_AUTHED_PER_DAY=1000         # authed per-user ceiling (day)
PLAYGROUND_DAILY_QUOTA_GLOBAL=5000                # global daily ceiling across anon + authed
