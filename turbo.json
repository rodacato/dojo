{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**/*.ts", "vitest.config.ts"]
    },
    "@dojo/e2e#test": {
      "dependsOn": ["^build"],
      "cache": false,
      "inputs": ["tests/**/*.ts", "playwright.config.ts"]
    },
    "@dojo/e2e#test:smoke": {
      "cache": false,
      "inputs": ["smoke/**/*.ts", "playwright.smoke.config.ts"]
    },
    "clean": {
      "cache": false
    }
  }
}
