{
  "name": "@dojo/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=../../.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:prod": "node dist/infrastructure/persistence/migrate.js",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=../../.env src/infrastructure/persistence/seed.ts",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@dojo/shared": "workspace:*",
    "@hono/node-server": "^1.19.11",
    "@hono/node-ws": "^1.3.0",
    "arctic": "^2.0.0",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.6.0",
    "hono-rate-limiter": "^0.5.0",
    "postgres": "^3.0.0",
    "resend": "^6.9.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-istanbul": "^2.0.0",
    "drizzle-kit": "^0.29.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
